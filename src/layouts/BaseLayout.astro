---
import { SEO } from 'astro-seo';

interface Props {
  title: string;
  description: string;
  image?: string;
  article?: {
    publishedTime?: string;
    modifiedTime?: string;
    tags?: string[];
  };
  breadcrumbs?: { name: string; item: string }[];
}

const { title, description, image, article, breadcrumbs } = Astro.props;
const canonicalURL = new URL(Astro.url.pathname, Astro.site).toString();
const ogImage = image
  ? new URL(image, Astro.site).toString()
  : new URL('/og-default.jpg', Astro.site).toString();

// Auto-derive breadcrumbs if not provided (skip homepage + error pages)
const autoCrumbs = (() => {
  if (breadcrumbs) return breadcrumbs;
  const path = Astro.url.pathname.replace(/\/$/, '');
  if (!path) return null;
  if (path === '/404' || path === '/404.html' || path.endsWith('/404.html')) return null;
  const parts = path.split('/').filter(Boolean);
  const crumbs = [{ name: 'Home', item: new URL('/', Astro.site).toString() }];
  let acc = '';
  for (let i = 0; i < parts.length; i++) {
    acc += '/' + parts[i];
    const isLast = i === parts.length - 1;
    const name = isLast
      ? title.split('—')[0].trim()
      : parts[i].charAt(0).toUpperCase() + parts[i].slice(1);
    crumbs.push({ name, item: new URL(acc + '/', Astro.site).toString() });
  }
  return crumbs;
})();

const breadcrumbLd = autoCrumbs && autoCrumbs.length > 1
  ? {
      '@context': 'https://schema.org',
      '@type': 'BreadcrumbList',
      itemListElement: autoCrumbs.map((c, i) => ({
        '@type': 'ListItem',
        position: i + 1,
        name: c.name,
        item: c.item,
      })),
    }
  : null;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="theme-color" content="#0564D1" />
    <meta name="application-name" content="Short n Sweet Digital" />
    <link rel="icon" type="image/png" href="https://storage.googleapis.com/msgsndr/LHvDkOgXpZdUYdjFzBff/media/66d68a8784ef295b74e11ebf.png" />
    <link rel="alternate" type="application/rss+xml" title="Short n Sweet Digital — Blog" href="/rss.xml" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="preload" as="style" href="https://fonts.googleapis.com/css2?family=Open+Sans:wght@400;600;700;800&display=swap" />
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Open+Sans:wght@400;600;700;800&display=swap" media="print" onload="this.media='all'" />
    <noscript><link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Open+Sans:wght@400;600;700;800&display=swap" /></noscript>
    <link rel="sitemap" href="/sitemap-index.xml" />
    <!-- Site-wide overrides (BorderGlow + StaggeredMenu + GHL polish) -->
    <script src="/assets/site-overrides.js" defer></script>
    <!-- GA4 -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-SG9EKTBZE0"></script>
    <script is:inline>window.dataLayer=window.dataLayer||[];function gtag(){dataLayer.push(arguments);}gtag('js',new Date());gtag('config','G-SG9EKTBZE0',{anonymize_ip:true});</script>
    <SEO
      title={title}
      description={description}
      canonical={canonicalURL}
      openGraph={{
        basic: {
          title,
          type: article ? 'article' : 'website',
          image: ogImage,
          url: canonicalURL,
        },
        optional: { description },
        article: article
          ? {
              publishedTime: article.publishedTime,
              modifiedTime: article.modifiedTime,
              tags: article.tags,
            }
          : undefined,
      }}
      twitter={{
        card: 'summary_large_image',
        title,
        description,
        image: ogImage,
      }}
    />
    {breadcrumbLd && (
      <script type="application/ld+json" set:html={JSON.stringify(breadcrumbLd)} />
    )}
  </head>
  <body>
    <a class="snd-skip-link" href="#main-content">Skip to content</a>
    <header class="site-header">
      <a class="brand" href="/" aria-label="Short n Sweet Digital — home">
        <img
          src="https://images.leadconnectorhq.com/image/f_webp/q_80/r_1200/u_https://assets.cdn.filesafe.space/LHvDkOgXpZdUYdjFzBff/media/67188f8028f9aa4e4a87fa1e.webp"
          alt="ShortNSweet Digital"
          width="260" height="70"
        />
      </a>
      <nav aria-label="Primary">
        <a href="/">Home</a>
        <a href="https://shortnsweetdigital.com/#section-ZTF8dMXlhU">Services</a>
        <a href="/blog/">Blog</a>
        <a href="/book-a-call/">Book a Call</a>
        <a href="https://app.shortnsweetdigital.com" rel="noopener">Login</a>
        <a href="https://www.skool.com/llmacademy/about?ref=7ec545cf11f44d1e9ebe40b09419916e" rel="noopener">LEARN</a>
        <a href="https://www.gohighlevel.com/?fp_ref=shortnsweet53&utm_source=site_nav&utm_medium=organic&utm_campaign=global_nav" rel="noopener" class="cta">Start free trial</a>
      </nav>
    </header>
    <main id="main-content">
      <slot />
    </main>
    <a class="snd-mobile-cta" href="https://www.gohighlevel.com/?fp_ref=shortnsweet53&utm_source=site&utm_medium=organic&utm_campaign=mobile_sticky" rel="noopener">
      Start free trial →
    </a>
    <footer class="site-footer">
      <p>&copy; {new Date().getFullYear()} Short n Sweet Digital. All rights reserved.</p>
    </footer>

    <style is:global>
      :root {
        --fg: #f8fafc;
        --bg: #0a090e;
        --muted: #cbd5e1;
        --accent: #188bf6;
        --accent-2: #0564D1;
        --border: #1f2937;
        --max-width: 72ch;
      }
      * { box-sizing: border-box; }
      .snd-skip-link {
        position: absolute; left: -9999px; top: 0;
        background: #0564D1; color: #fff; padding: 8px 14px;
        border-radius: 0 0 8px 0; z-index: 10000;
        text-decoration: none; font-weight: 700;
      }
      .snd-skip-link:focus { left: 0; }
      html, body {
        margin: 0;
        padding: 0;
        font-family: 'Open Sans', -apple-system, BlinkMacSystemFont, 'Segoe UI',
          Roboto, 'Helvetica Neue', Arial, sans-serif;
        color: var(--fg);
        background: var(--bg);
        line-height: 1.6;
      }
      /* Match homepage: city image as fixed background, dark overlay for legibility */
      body::before {
        content: "";
        position: fixed;
        inset: 0;
        z-index: -1;
        background:
          linear-gradient(180deg, rgba(10,9,14,0.88) 0%, rgba(15,23,42,0.92) 100%),
          url('https://images.leadconnectorhq.com/image/f_webp/q_80/r_1200/u_https://assets.cdn.filesafe.space/LHvDkOgXpZdUYdjFzBff/media/66ef6250acfd667f6577ccee.jpeg') center/cover no-repeat;
        background-attachment: fixed, fixed;
      }
      main { position: relative; z-index: 1; }
      main {
        max-width: var(--max-width);
        margin: 0 auto;
        padding: 2rem 1.25rem 4rem;
      }
      h1, h2, h3, h4 {
        line-height: 1.2;
        color: var(--fg);
      }
      a { color: var(--accent); }
      a:hover { text-decoration: underline; }
      img { max-width: 100%; height: auto; }
      .site-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 1rem 1.5rem;
        border-bottom: 1px solid var(--border);
      }
      .site-header .brand {
        display: inline-flex;
        align-items: center;
        text-decoration: none;
      }
      .site-header .brand img {
        display: block;
        height: 56px;
        width: auto;
      }
      .site-header nav {
        display: flex;
        align-items: center;
        gap: 0.25rem;
      }
      .site-header nav a {
        margin-left: 0.5rem;
        padding: 0.4rem 0.75rem;
        color: var(--fg);
        text-decoration: none;
        font-family: 'Open Sans', sans-serif;
        font-weight: 600;
        font-size: 0.95rem;
        border-radius: 6px;
      }
      .site-header nav a:hover { background: rgba(255,255,255,0.06); }
      .site-header nav a.cta {
        background: var(--accent);
        color: #fff;
        padding: 0.5rem 1rem;
        border-radius: 999px;
      }
      .snd-mobile-cta {
        display: none;
        position: fixed;
        left: 12px;
        right: 12px;
        bottom: 12px;
        z-index: 999;
        text-align: center;
        background: linear-gradient(120deg, #0564D1, #5271FF);
        color: #fff;
        font-weight: 700;
        padding: 14px 18px;
        border-radius: 999px;
        text-decoration: none;
        box-shadow: 0 12px 32px rgba(5, 100, 209, 0.4);
        font-family: 'Open Sans', sans-serif;
      }
      @media (max-width: 720px) {
        .snd-mobile-cta { display: block; }
        main { padding-bottom: 5rem; }
      }
      .site-footer {
        border-top: 1px solid var(--border);
        padding: 1.5rem;
        text-align: center;
        color: var(--muted);
        font-size: 0.9rem;
      }
    </style>
  </body>
</html>
