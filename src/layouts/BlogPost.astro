---
import type { CollectionEntry } from 'astro:content';
import BaseLayout from './BaseLayout.astro';
import CTA from '../components/CTA.astro';
import AudioPlayer from '../components/AudioPlayer.astro';

type Heading = { depth: number; slug: string; text: string };
type RelatedPost = { slug: string; title: string; description: string; heroImage?: string; pubDate: Date };
type HowToStep = { '@type': 'HowToStep'; position: number; name: string; text: string };
type HowTo = { name: string; steps: HowToStep[] };
type Props = CollectionEntry<'blog'>['data'] & {
  slug: string;
  faqs?: { question: string; answer: string }[];
  headings?: Heading[];
  relatedPosts?: RelatedPost[];
  readingTime?: number;
  howTo?: HowTo | null;
};

const {
  title, description, pubDate, updatedDate, heroImage, audio, tags, slug, faqs,
  headings = [], relatedPosts = [], readingTime, howTo,
} = Astro.props;

// Only H2s in the TOC. H3s deepen the visual noise without aiding scanning.
const tocItems = headings.filter((h) => h.depth === 2);

const formattedDate = new Intl.DateTimeFormat('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
}).format(pubDate);

// JSON-LD: Article (Google's preferred type for richer SERP eligibility) +
// BreadcrumbList. Image required for "Article" rich card eligibility — falls
// back to the og-default if a post lacks a hero.
const canonicalUrl = new URL(`/blog/${slug}/`, Astro.site).toString();
const articleImage = heroImage
  ? new URL(heroImage, Astro.site).toString()
  : new URL('/og-default.jpg', Astro.site).toString();
const ldJson = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'Article',
      '@id': `${canonicalUrl}#article`,
      headline: title,
      description,
      datePublished: pubDate.toISOString(),
      dateModified: (updatedDate ?? pubDate).toISOString(),
      mainEntityOfPage: { '@type': 'WebPage', '@id': canonicalUrl },
      image: { '@type': 'ImageObject', url: articleImage, width: 1200, height: 630 },
      author: {
        '@type': 'Organization',
        name: 'Short n Sweet Digital',
        url: 'https://shortnsweetdigital.com/',
      },
      publisher: {
        '@type': 'Organization',
        name: 'Short n Sweet Digital',
        url: 'https://shortnsweetdigital.com/',
        logo: {
          '@type': 'ImageObject',
          url: 'https://storage.googleapis.com/msgsndr/LHvDkOgXpZdUYdjFzBff/media/66d68a8784ef295b74e11ebf.png',
        },
      },
      keywords: tags.join(', '),
      inLanguage: 'en-US',
      // Speakable marks the lede and key takeaways as Google Assistant-readable.
      speakable: {
        '@type': 'SpeakableSpecification',
        cssSelector: ['.lede', '.post-body > blockquote:first-of-type'],
      },
    },
    {
      '@type': 'BreadcrumbList',
      itemListElement: [
        { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://shortnsweetdigital.com/' },
        { '@type': 'ListItem', position: 2, name: 'Blog', item: 'https://shortnsweetdigital.com/blog/' },
        { '@type': 'ListItem', position: 3, name: title, item: canonicalUrl },
      ],
    },
    ...(faqs && faqs.length > 0
      ? [{
          '@type': 'FAQPage',
          mainEntity: faqs.map((f) => ({
            '@type': 'Question',
            name: f.question,
            acceptedAnswer: { '@type': 'Answer', text: f.answer },
          })),
        }]
      : []),
    ...(howTo
      ? [{
          '@type': 'HowTo',
          name: howTo.name,
          step: howTo.steps,
          inLanguage: 'en-US',
        }]
      : []),
  ],
};
---

<BaseLayout
  title={title}
  description={description}
  image={heroImage}
  article={{
    publishedTime: pubDate.toISOString(),
    modifiedTime: (updatedDate ?? pubDate).toISOString(),
    tags,
  }}
>
  <script type="application/ld+json" set:html={JSON.stringify(ldJson)} />

  <article>
    <header class="post-header">
      <p class="meta">
        <time datetime={pubDate.toISOString()}>{formattedDate}</time>
        {readingTime && <> · {readingTime} min read</>}
        {updatedDate && (
          <>
            {' · Updated '}
            <time datetime={updatedDate.toISOString()}>
              {new Intl.DateTimeFormat('en-US', { dateStyle: 'long' }).format(updatedDate)}
            </time>
          </>
        )}
      </p>
      <h1>{title}</h1>
      <p class="lede">{description}</p>
      {heroImage && (
        <img class="hero" src={heroImage} alt={title} loading="eager" />
      )}
    </header>

    {audio && <AudioPlayer src={audio} title={title} />}

    {tocItems.length >= 3 && (
      <nav class="toc" aria-label="Table of contents">
        <p class="toc-title">In this post</p>
        <ol>
          {tocItems.map((h) => (
            <li><a href={`#${h.slug}`}>{h.text}</a></li>
          ))}
        </ol>
      </nav>
    )}

    <div class="post-body">
      <slot />
    </div>

    <CTA campaign={slug} />

    {relatedPosts.length > 0 && (
      <section class="related" aria-labelledby="related-title">
        <h2 id="related-title">Keep reading</h2>
        <div class="related-grid">
          {relatedPosts.map((p) => (
            <a class="related-card" href={`/blog/${p.slug}/`}>
              {p.heroImage && <img src={p.heroImage} alt="" loading="lazy" />}
              <div class="related-body">
                <h3>{p.title}</h3>
                <p>{p.description}</p>
              </div>
            </a>
          ))}
        </div>
      </section>
    )}

    {tags.length > 0 && (
      <footer class="tags">
        {tags.map((tag) => <span class="tag">#{tag}</span>)}
      </footer>
    )}
  </article>

  <style>
    .post-header { margin-bottom: 2rem; }
    .meta { color: var(--muted); font-size: 0.9rem; margin: 0; }
    .lede { font-size: 1.15rem; color: var(--muted); }
    .hero { border-radius: 12px; margin: 1.5rem 0; }
    .post-body :global(h2) { margin-top: 2.5rem; }
    .post-body :global(h3) { margin-top: 2rem; }
    .post-body :global(pre) {
      background: #0f172a;
      color: #f8fafc;
      padding: 1rem;
      border-radius: 8px;
      overflow-x: auto;
    }
    .post-body :global(blockquote) {
      border-left: 4px solid var(--accent);
      margin: 1.5rem 0;
      padding: 0.25rem 1rem;
      color: var(--muted);
    }
    .tags { margin-top: 2rem; }
    .tag {
      display: inline-block;
      margin-right: 0.5rem;
      padding: 0.15rem 0.6rem;
      background: rgba(5, 100, 209, 0.15);
      border-radius: 999px;
      font-size: 0.85rem;
      color: #93c5fd;
    }

    .toc {
      margin: 2rem 0;
      padding: 1rem 1.25rem;
      border: 1px solid rgba(148, 163, 184, 0.18);
      border-radius: 10px;
      background: rgba(15, 23, 42, 0.5);
    }
    .toc-title {
      margin: 0 0 0.5rem;
      font-size: 0.78rem;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      color: #93c5fd;
      font-weight: 600;
    }
    .toc ol {
      margin: 0;
      padding-left: 1.25rem;
      color: var(--muted);
    }
    .toc li { margin: 0.2rem 0; }
    .toc a { color: inherit; text-decoration: none; }
    .toc a:hover { color: #f8fafc; text-decoration: underline; }

    .related { margin-top: 3rem; padding-top: 2rem; border-top: 1px solid rgba(148, 163, 184, 0.18); }
    .related h2 { margin: 0 0 1rem; }
    .related-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
      gap: 1rem;
    }
    .related-card {
      display: flex;
      flex-direction: column;
      border-radius: 10px;
      overflow: hidden;
      background: rgba(15, 23, 42, 0.5);
      border: 1px solid rgba(148, 163, 184, 0.18);
      color: inherit;
      text-decoration: none;
      transition: transform 0.15s ease, border-color 0.15s ease;
    }
    .related-card:hover {
      transform: translateY(-2px);
      border-color: rgba(59, 155, 255, 0.5);
    }
    .related-card img { width: 100%; aspect-ratio: 16/9; object-fit: cover; display: block; }
    .related-body { padding: 0.85rem 1rem; }
    .related-body h3 { margin: 0 0 0.4rem; font-size: 1rem; line-height: 1.3; }
    .related-body p { margin: 0; font-size: 0.85rem; color: var(--muted); line-height: 1.4;
      display: -webkit-box; -webkit-line-clamp: 3; -webkit-box-orient: vertical; overflow: hidden; }
  </style>
</BaseLayout>
