---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';

const posts = (await getCollection('blog', ({ data }) => !data.draft)).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);
const latest = posts.slice(0, 6);
---

<BaseLayout
  title="Agentic Jimmy — the agency stack playbook"
  description="One platform for CRM, email, SMS, sites, and pipelines. Agency playbooks, reviews, and how-tos — new post every day."
>
  <section class="hero">
    <h1>The agency stack playbook.</h1>
    <p>
      Reviews, comparisons, and playbooks for running a lean marketing agency on
      one platform. New post every weekday.
    </p>
    <a
      class="hero-cta"
      href="/trial?utm_source=site&utm_medium=organic&utm_campaign=homepage_hero"
    >
      Start your free 14-day trial →
    </a>
  </section>

  <section class="latest">
    <h2>Latest posts</h2>
    <ul>
      {latest.map((post) => (
        <li>
          <a href={`/blog/${post.slug}`}>
            <h3>{post.data.title}</h3>
            <p>{post.data.description}</p>
            <time datetime={post.data.pubDate.toISOString()}>
              {new Intl.DateTimeFormat('en-US', { dateStyle: 'long' }).format(post.data.pubDate)}
            </time>
          </a>
        </li>
      ))}
    </ul>
    <p><a href="/blog">Browse all posts →</a></p>
  </section>
</BaseLayout>

<style>
  .hero { padding: 2rem 0 3rem; text-align: center; }
  .hero h1 { font-size: 2.5rem; margin-bottom: 0.5rem; }
  .hero p { color: var(--muted); font-size: 1.1rem; max-width: 52ch; margin: 0 auto 1.5rem; }
  .hero-cta {
    display: inline-block;
    padding: 0.85rem 1.75rem;
    background: var(--accent);
    color: #0f172a;
    font-weight: 700;
    border-radius: 8px;
    text-decoration: none;
  }
  .latest { margin-top: 3rem; }
  .latest ul { list-style: none; padding: 0; }
  .latest li { border-top: 1px solid #e2e8f0; padding: 1.25rem 0; }
  .latest a { text-decoration: none; color: inherit; display: block; }
  .latest h3 { margin: 0 0 0.25rem; color: var(--fg); }
  .latest p { margin: 0 0 0.25rem; color: var(--muted); }
  .latest time { color: var(--muted); font-size: 0.85rem; }
</style>
