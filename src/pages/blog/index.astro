---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

const posts = (await getCollection('blog', ({ data }) => !data.draft)).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);

const fmt = (d: Date) =>
  new Intl.DateTimeFormat('en-US', { year: 'numeric', month: 'long', day: 'numeric', timeZone: 'UTC' }).format(d);
---

<BaseLayout
  title="Blog — Short n Sweet Digital"
  description="Honest comparisons, agency-tested playbooks, and AI automation deep-dives. New post every weekday."
>
  <section class="blog-hero" data-snd-reveal>
    <p class="eyebrow">The Blog</p>
    <h1>Insights, comparisons &amp; playbooks</h1>
    <p class="lede">
      Honest comparisons, agency-tested playbooks, and AI automation
      deep-dives — new post every weekday.
    </p>
    <form data-snd-newsletter class="newsletter">
      <label for="snd-newsletter-email" class="sr-only">Email address</label>
      <input
        id="snd-newsletter-email"
        type="email"
        name="email"
        placeholder="you@youragency.com"
        required
        autocomplete="email"
      />
      <button type="submit">Get the playbook →</button>
      <p class="newsletter-note">One short email a week. No spam. Unsubscribe in one click.</p>
    </form>
  </section>

  <ul class="post-grid">
    {posts.map((post) => (
      <li class="snd-bg-card">
        <a href={`/blog/${post.slug}/`}>
          {post.data.heroImage ? (
            <img src={post.data.heroImage} alt={post.data.title} loading="lazy" />
          ) : (
            <div class="placeholder">{post.data.title.slice(0, 60)}</div>
          )}
          <div class="card-body">
            <time datetime={post.data.pubDate.toISOString()}>{fmt(post.data.pubDate)}</time>
            <h2>{post.data.title}</h2>
            <p>{post.data.description}</p>
            <span class="read-more">Read post →</span>
          </div>
        </a>
      </li>
    ))}
  </ul>
</BaseLayout>

<style>
  .blog-hero { padding: 1.5rem 0 2.5rem; text-align: center; }
  .eyebrow { color: #5271FF; font-weight: 800; letter-spacing: 0.12em; margin: 0 0 0.5rem; text-transform: uppercase; font-size: 0.85rem; }
  h1 { font-size: 2.4rem; line-height: 1.15; margin: 0 0 1rem; }
  .lede { color: var(--muted); font-size: 1.1rem; max-width: 580px; margin: 0 auto; }
  .sr-only {
    position: absolute; width: 1px; height: 1px;
    padding: 0; margin: -1px; overflow: hidden; clip: rect(0,0,0,0);
    white-space: nowrap; border: 0;
  }
  .newsletter {
    max-width: 520px;
    margin: 1.5rem auto 0;
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    justify-content: center;
  }
  .newsletter input[type="email"] {
    flex: 1 1 240px;
    min-width: 0;
    padding: 0.75rem 1rem;
    border-radius: 10px;
    border: 1px solid rgba(148, 163, 184, 0.3);
    background: rgba(15, 23, 42, 0.6);
    color: var(--fg, #f8fafc);
    font-size: 1rem;
  }
  .newsletter input[type="email"]::placeholder { color: rgba(148, 163, 184, 0.7); }
  .newsletter input[type="email"]:focus {
    outline: none;
    border-color: #3b9bff;
    box-shadow: 0 0 0 3px rgba(59, 155, 255, 0.25);
  }
  .newsletter button {
    padding: 0.75rem 1.25rem;
    border-radius: 10px;
    border: 0;
    background: linear-gradient(90deg, #188bf6, #5271FF);
    color: #fff;
    font-weight: 700;
    font-size: 0.98rem;
    cursor: pointer;
  }
  .newsletter button:hover { filter: brightness(1.08); }
  .newsletter-note {
    flex: 1 1 100%;
    margin: 0.5rem 0 0;
    text-align: center;
    color: rgba(148, 163, 184, 0.85);
    font-size: 0.78rem;
  }

  .post-grid {
    list-style: none;
    padding: 0;
    margin: 1.5rem 0 0;
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 24px;
  }
  .post-grid li {
    background: rgba(15, 23, 42, 0.65);
    border: 1px solid rgba(5, 100, 209, 0.22);
    border-radius: 16px;
    overflow: hidden;
    transition: transform 0.2s ease, border-color 0.2s ease, box-shadow 0.2s ease;
  }
  .post-grid li:hover {
    transform: translateY(-4px);
    border-color: rgba(82, 113, 255, 0.55);
    box-shadow: 0 16px 40px rgba(5, 100, 209, 0.25);
  }
  .post-grid a { display: flex; flex-direction: column; text-decoration: none; color: inherit; height: 100%; }
  .post-grid img, .placeholder { width: 100%; aspect-ratio: 16/9; object-fit: cover; display: block; }
  .placeholder {
    background: linear-gradient(135deg, #0564D1, #5271FF);
    color: #fff;
    font-weight: 800;
    font-size: 1.05rem;
    text-align: center;
    padding: 0 20px;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .card-body { padding: 22px 22px 24px; display: flex; flex-direction: column; gap: 10px; flex: 1; }
  .card-body time { color: #5271FF; font-size: 0.78rem; font-weight: 700; letter-spacing: 0.06em; text-transform: uppercase; }
  .card-body h2 { margin: 0; font-size: 1.18rem; line-height: 1.3; color: #fff; font-weight: 700; }
  .card-body p { margin: 0; color: #cbd5e1; font-size: 0.93rem; line-height: 1.5; flex: 1; }
  .read-more { color: #5271FF; font-weight: 700; font-size: 0.88rem; margin-top: 4px; }

  /* override BaseLayout's narrow main */
  :global(main:has(.post-grid)) { max-width: 1100px; }
</style>
