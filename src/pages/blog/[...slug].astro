---
import { getCollection } from 'astro:content';
import BlogPost from '../../layouts/BlogPost.astro';

export async function getStaticPaths() {
  const posts = await getCollection('blog', ({ data }) => !data.draft);
  return posts.map((post) => ({
    params: { slug: post.slug },
    props: post,
  }));
}

const post = Astro.props;
const { Content, headings } = await post.render();

// Reading time: 220 wpm is the conventional estimate for non-technical content.
const wordCount = (post.body || '').trim().split(/\s+/).length;
const readingTime = Math.max(1, Math.round(wordCount / 220));

// Related posts: score every other published post by tag overlap, take top 3.
const allPosts = await getCollection('blog', ({ data }) => !data.draft);
const currentTags = new Set((post.data.tags || []).map((t) => t.toLowerCase()));
const relatedPosts = allPosts
  .filter((p) => p.slug !== post.slug)
  .map((p) => {
    const overlap = (p.data.tags || []).filter((t) => currentTags.has(t.toLowerCase())).length;
    return { post: p, overlap };
  })
  .filter((x) => x.overlap > 0)
  .sort((a, b) => b.overlap - a.overlap || b.post.data.pubDate.valueOf() - a.post.data.pubDate.valueOf())
  .slice(0, 3)
  .map(({ post: p }) => ({
    slug: p.slug,
    title: p.data.title,
    description: p.data.description,
    heroImage: p.data.heroImage,
    pubDate: p.data.pubDate,
  }));

// Extract FAQ-style Q&A from H2s + their first paragraph for FAQPage JSON-LD.
// Heuristic: any H2 that ends with "?" OR starts with What/How/Why/When/Is/Does
// becomes a Question. Answer is the first paragraph after the heading.
const body = post.body || '';
const sections = body.split(/^##\s+/m).slice(1);
const QUESTION_PREFIX = /^(what|how|why|when|is|does|do|are|can|should|will|which|who)\b/i;
const faqs = sections
  .map((sec) => {
    const lines = sec.split('\n');
    const heading = (lines[0] || '').trim();
    if (!heading) return null;
    if (!heading.endsWith('?') && !QUESTION_PREFIX.test(heading)) return null;
    // Grab first non-empty, non-blockquote, non-bullet paragraph
    let answer = '';
    for (let i = 1; i < lines.length; i++) {
      const l = lines[i].trim();
      if (!l || l.startsWith('>') || l.startsWith('-') || l.startsWith('*') || l.startsWith('![')) continue;
      if (l.startsWith('#')) break;
      answer = l;
      break;
    }
    if (!answer) return null;
    // Strip markdown links/bold/italic
    answer = answer
      .replace(/\[([^\]]+)\]\([^)]+\)/g, '$1')
      .replace(/\*\*([^*]+)\*\*/g, '$1')
      .replace(/\*([^*]+)\*/g, '$1')
      .replace(/`([^`]+)`/g, '$1')
      .replace(/<[^>]+>/g, '')
      .trim();
    if (answer.length < 40 || answer.length > 600) return null;
    const question = heading.endsWith('?') ? heading : heading + '?';
    return { question, answer };
  })
  .filter(Boolean)
  .slice(0, 6);

// HowTo schema: extract a "How to..." H2 and the numbered list under it.
// Google's HowTo rich result requires at least 2 steps.
function extractHowTo() {
  const m = body.match(/^##\s+(How (?:to|do)[^\n]*)\n([\s\S]*?)(?=\n##\s|$)/im);
  if (!m) return null;
  const name = m[1].trim();
  const block = m[2];
  // Match numbered list items "1. ..." or bullet list items "- **...**"
  const numbered = [...block.matchAll(/^\s*\d+\.\s+(.+?)(?=\n\s*\d+\.|\n##|\n\n[A-Z]|$)/gms)];
  const bulleted = [...block.matchAll(/^\s*[-*]\s+\*\*([^*]+)\*\*[:.]?\s*(.+?)(?=\n\s*[-*]|\n##|\n\n[A-Z]|$)/gms)];
  const steps = numbered.length >= 2 ? numbered.map((mm, i) => ({
    '@type': 'HowToStep',
    position: i + 1,
    name: mm[1].split(/[.!?:\n]/)[0].trim().slice(0, 110),
    text: mm[1].replace(/\s+/g, ' ').trim().slice(0, 500),
  })) : bulleted.length >= 2 ? bulleted.slice(0, 8).map((mm, i) => ({
    '@type': 'HowToStep',
    position: i + 1,
    name: mm[1].trim().slice(0, 110),
    text: `${mm[1].trim()}: ${mm[2].replace(/\s+/g, ' ').trim()}`.slice(0, 500),
  })) : null;
  if (!steps) return null;
  return { name, steps };
}
const howTo = extractHowTo();
---

<BlogPost
  {...post.data}
  slug={post.slug}
  faqs={faqs}
  headings={headings}
  relatedPosts={relatedPosts}
  readingTime={readingTime}
  howTo={howTo}
>
  <Content />
</BlogPost>
